# APP
APP_NAME=AccountingSystem
NODE_ENV=development
PORT=5000

# FRONTEND
FRONTEND_URL=http://localhost:3000

# DATABASE
DATABASE_URL="postgresql://postgres:0000@localhost:5432/accounting_db?schema=public"

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=0000
DB_NAME=accounting_db

# JWT
JWT_SECRET=supersecretkey
JWT_EXPIRES_IN=7d

# LOGGING
LOG_LEVEL=debug

# ─── STORAGE (MinIO / S3-compatible) — OPTIONAL ─────────────────────────────
# Turn this on to enable file attachments on expenses, payments and employees.
# Leave STORAGE_ENABLED=false (or unset) to hide the upload UI entirely.
#
# Local setup: `docker compose --profile storage up -d`
# Console:     http://localhost:9001 (user: the access key, pass: the secret)
#
# IMPORTANT: STORAGE_ENDPOINT is a HOSTNAME ONLY — no scheme, no port.
#   ✓  localhost
#   ✓  s3.eu-west-1.amazonaws.com
#   ✗  http://localhost:9000   ← will crash with "Invalid endPoint"
# Use STORAGE_USE_SSL to pick http (false) vs https (true); STORAGE_PORT
# is a separate field.
STORAGE_ENABLED=true
STORAGE_ENDPOINT=localhost
STORAGE_PORT=9000
STORAGE_USE_SSL=false
STORAGE_ACCESS_KEY=admin
STORAGE_SECRET_KEY=StrongPassword123
STORAGE_BUCKET=accounting-attachments
STORAGE_REGION=us-east-1
# Presigned download URLs expire after this many seconds (15 min default).
STORAGE_URL_TTL=900
# Hard cap on a single upload size, in bytes (default 25 MB).
STORAGE_MAX_FILE_SIZE=26214400